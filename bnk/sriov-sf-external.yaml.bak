apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: sf-external
  namespace: f5-bnk
  annotations:
    k8s.v1.cni.cncf.io/resourceName: intel.com/intel_sriov_netdevice
spec:
  config: |
    {
      "cniVersion": "0.3.1",
      "type": "sriov",
      "name": "sf-external",
      "ipam": {
        "type": "host-local",
        "subnet": "192.168.48.0/24",
        "rangeStart": "192.168.48.245",
        "rangeEnd": "192.168.48.250",
        "gateway": "192.168.48.1"
      }
    }
