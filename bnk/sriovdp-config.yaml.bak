apiVersion: v1
kind: ConfigMap
metadata:
  name: sriovdp-config
  namespace: kube-system
data:
  config.json: |
    {
      "resourceList": [
        {
          "resourceName": "intel_sriov_netdevice",
          "selectors": {
            "vendors": ["8086"],
            "devices": ["154c", "37cd"],
            "pfNames": ["enp59s0f0np0", "enp5s0f0np0"],
            "drivers": ["iavf"]
          }
        }
      ]
    }
